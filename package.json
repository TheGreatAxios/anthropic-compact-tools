{
  "name": "anthropic-compact-tools",
  "version": "0.1.1",
  "description": "Compact-syntax tool calling for the Anthropic TypeScript SDK. Replaces verbose tool_use JSON with a compact wire format to reduce output tokens.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "build": "tsdown",
    "prepublishOnly": "bun run build",
    "typecheck": "bunx tsc --noEmit",
    "bench": "bun run bench/bench-v2.ts",
    "bench:v1": "bun run bench/bench-v1.ts",
    "bench:v2": "bun run bench/bench-v2.ts",
    "bench:live": "bun run bench/bench-v2.ts",
    "ab-test": "bun run bench/ab-test.ts",
    "compare": "bun run bench/compare.ts"
  },
  "keywords": [
    "anthropic",
    "claude",
    "tool-calling",
    "tools",
    "compact",
    "wire-format",
    "tokens",
    "llm",
    "prompt-caching"
  ],
  "license": "MIT",
  "author": "Sawyer Cutler <sawyer@dirtroad.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheGreatAxios/anthropic-compact-tools.git"
  },
  "bugs": {
    "url": "https://github.com/TheGreatAxios/anthropic-compact-tools/issues"
  },
  "homepage": "https://github.com/TheGreatAxios/anthropic-compact-tools#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "js-tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "tsdown": "0.22.0",
    "typescript": "^6.0.3"
  }
}
